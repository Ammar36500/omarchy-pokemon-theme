{
    "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/dev/doc/json_schema.json",
    "logo": {
        "type": "none"
    },
    "display": {
        "separator": "  "
    },
    "modules": [
        {
            "type": "command",
            "text": "pokemon-colorscripts -r --no-title",
            "key": "\n",
            "outputColor": true
        },
        {
            "type": "custom",
            "format": "┌───────────────────────────────────────────────────────────────────────────────────┐"
        },
        {
            "type": "os",
            "key": "  󰀥 OS",
            "keyColor": "red",
            "paddingLeft": 2
        },
        {
            "type": "bios",
            "key": "  󱢌 Bios",
            "keyColor": "red",
            "paddingLeft": 2
        },
        {
            "type": "kernel",
            "key": "   Kernel",
            "keyColor": "red",
            "paddingLeft": 2
        },
        {
            "type": "packages",
            "key": "  󰏗 Packages",
            "keyColor": "green",
            "paddingLeft": 2
        },
        {
            "type": "display",
            "key": "  󰹑 Display",
            "keyColor": "green",
            "paddingLeft": 2
        },
        {
            "type": "wm",
            "key": "   WM",
            "format": "{2}",
            "keyColor": "yellow",
            "paddingLeft": 2
        },
        {
            "type": "terminalfont",
            "key": "   Font",
            "keyColor": "yellow",
            "paddingLeft": 2
        },
        {
            "type": "terminal",
            "key": "   Terminal",
            "format": "{1}",
            "keyColor": "yellow",
            "paddingLeft": 2
        },
        "break",
        {
            "type": "colors",
            "paddingLeft": 2,
            "symbol": "circle"
        },
        "break",
        {
            "type": "cpu",
            "format": "{1}",
            "key": "   CPU",
            "keyColor": "blue",
            "paddingLeft": 2
        },
        {
            "type": "gpu",
            "format": "{1} {2} {12} Ghz",
            "key": "  󰋵 GPU",
            "keyColor": "blue",
            "paddingLeft": 2
        },
        {
            "type": "memory",
            "key": "  󰀚 Memory",
            "keyColor": "blue",
            "paddingLeft": 2
        },
        {
            "type": "shell",
            "format": "{1} v{4}",
            "key": "  󰘳 Shell",
            "keyColor": "magenta",
            "paddingLeft": 2
        },
        {
            "type": "disk",
            "key": "  󰀚 Disk",
            "keyColor": "magenta",
            "paddingLeft": 2
        },
        {
            "type": "command",
            "key": "  󱦟 OS Age ",
            "keyColor": "red",
            "text": "birth_install=$(stat -c %W /); current=$(date +%s); time_progression=$((current - birth_install)); days_difference=$((time_progression / 86400)); echo $days_difference days",
            "paddingLeft": 2
        },
        {
            "type": "uptime",
            "key": "  󱫐 Uptime ",
            "keyColor": "red",
            "paddingLeft": 2
        },
        {
            "type": "host",
            "key": "  󰀥 Machine",
            "format": "{name}{?vendor} ({vendor}){?}",
            "keyColor": "red",
            "paddingLeft": 2
        },
        {
            "type": "custom",
            "format": "└───────────────────────────────────────────────────────────────────────────────────┘"
        }
    ]
}

